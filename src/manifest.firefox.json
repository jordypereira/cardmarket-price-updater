{
  "manifest_version": 2,
  "name": "Cardmarket Price Updater",
  "version": "0.1.0",
  "description": "Find and prefill lowest same-language prices for your Cardmarket offers.",
  "permissions": ["storage", "tabs", "https://www.cardmarket.com/*", "https://cardmarket.com/*"],
  "browser_action": {
    "default_title": "Cardmarket Price Updater",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://www.cardmarket.com/*/Stock/Offers/Singles*", "https://cardmarket.com/*/Stock/Offers/Singles*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.cardmarket.com/*/Products/Singles/*", "https://cardmarket.com/*/Products/Singles/*"],
      "js": ["scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "cardmarket-price-updater@local",
      "strict_min_version": "128.0"
    }
  }
}
