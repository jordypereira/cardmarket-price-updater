{
  "manifest_version": 3,
  "name": "Cardmarket Price Updater",
  "version": "0.1.0",
  "description": "Find and prefill lowest same-language prices for your Cardmarket offers.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.cardmarket.com/*", "https://cardmarket.com/*"],
  "action": {
    "default_title": "Cardmarket Price Updater",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.cardmarket.com/*/Stock/Offers/Singles*", "https://cardmarket.com/*/Stock/Offers/Singles*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
